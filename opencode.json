{
  "$schema": "https://opencode.ai/config.json",
  "disabled_providers": ["zen"],
  "watcher": {
    "ignore": ["node_modules/**", "dist/**", ".git/**", "target/**"]
  },
  "agent": {
    "general": {
      "model": "opencode-go/minimax-m2.5"
    },
    "explore": {
      "model": "opencode-go/minimax-m2.7"
    },
    "build": {
      "model": "opencode-go/minimax-m2.5"
    },
    "title": {
      "model": "opencode-go/minimax-m2.5"
    },
    "summary": {
      "model": "opencode-go/minimax-m2.5"
    },
    "plan": {
      "model": "opencode-go/glm-5.1"
    }
  },
  "model": "opencode-go/glm-5.1",
  "small_model": "opencode-go/minimax-m2.5",
  "permission": {
    "edit": "allow",
    "bash": {
      "git diff *": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "git status *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "fd *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "wc *": "allow",
      "ls *": "allow",
      "just *": "allow",
      "cargo test *": "allow",
      "cargo clippy *": "allow",
      "cargo check *": "allow",
      "*": "ask"
    }
  },
  "share": "disabled",
  "plugin": [
    "https://github.com/inkdust2021/opencode-vibeguard.git#f965b33468bafa27ac0654a04f5ed3c7c29c9b13"
  ],
  "instructions": [
    "CONTRIBUTING.md",
    "docs/guidelines.md",
    ".cursor/rules/*.md",
    "CLAUDE.md",
    "AGENTS.md"
  ],
  "mcp": {
    "Context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "Grep Github": {
      "oauth": {},
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    "exa-search": {
      "oauth": {},
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?tools=web_search_exa,get_code_context_exa,crawling_exa,deep_researcher_start,deep_researcher_check"
    }
  },
  "provider": {
    "ollama": {
      "models": {
        "glm-4.7-flash": {
          "name": "glm-4.7-flash"
        },
        "qwen3.5:9b": {
          "name": "qwen3.5:9b"
        }
      },
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      }
    },
    "openrouter": {
      "models": {},
      "options": {
        "data_collection": "deny"
      }
    },
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio",
      "options": {
        "baseURL": "http://localhost:1234/v1"
      },
      "models": {
        "glm-4.7-flash": {
          "name": "GLM 4.7 Flash MXFP4 MoE@gguf-uknw",
          "variants": {
            "none": {
              "reasoningEffort": "none"
