            "medium": {
              "reasoningEffort": "medium"
            },
            "high": {
              "reasoningEffort": "high"
            },
            "xhigh": {
              "reasoningEffort": "xhigh"
            }
          }
        }
      }
    },
    "llamabarn": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LlamaBarn",
      "options": {
        "baseURL": "http://localhost:2276/v1"
      },
      "models": {
        "gemma-3-270m": {
          "name": "gemma-3-270m"
        },
        "gemma-4-31b-q4": {
          "name": "gemma-4-31b-q4"
        },
        "glm-4.7-flash": {
          "name": "glm-4.7-flash"
        },
        "qwen-3.5-medium-27b": {
          "name": "qwen-3.5-medium-27b"
        },
        "qwen-3.5-small-4b": {
          "name": "qwen-3.5-small-4b"
        }
      }
    }
  },
  "server": {
    "cors": [
      "http://localhost:4096",
      "http://opencode-macpro.local:4096",
      "https://macpro.sparrow-tet.ts.net/oc"
    ],
    "mdns": true,
    "mdnsDomain": "opencode-macpro.local",
    "hostname": "127.0.0.1",
    "port": 4096
  }
}
