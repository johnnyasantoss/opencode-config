{
  "$schema": "https://opencode.ai/config.json",
  "disabled_providers": ["zen"],
  "watcher": {
    "ignore": ["node_modules/**", "dist/**", ".git/**", "target/**"]
  },
  "agent": {
    "general": {
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "high"
    },
    "explore": {
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "medium"
    },
    "build": {
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "high"
    },
    "title": {
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "low"
    },
    "summary": {
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "low"
    },
    "compaction": {
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "high"
    },
    "plan": {
      "model": "opencode-go/deepseek-v4-pro",
      "variant": "max"
    },
    "git-master": {
      "model": "opencode-go/mimo-v2.5-pro"
    },
    "orchestrator": {
      "model": "opencode-go/deepseek-v4-pro",
      "variant": "max"
    },
    "researcher": {
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "medium"
    },
    "review": {
      "model": "opencode-go/kimi-k2.6"
    }
  },
  "model": "opencode-go/deepseek-v4-pro",
  "small_model": "opencode-go/deepseek-v4-flash",
  "permission": {
    "edit": "allow",
    "bash": {
      "*": "ask",
      "git diff *": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "git status *": "allow",
      "git branch *": "allow",
      "echo *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "fd *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "wc *": "allow",
      "ls *": "allow",
      "just *": "allow",
      "cargo test *": "allow",
      "cargo nextest *": "allow",
      "cargo clippy *": "allow",
      "cargo check *": "allow"
    }
  },
  "share": "disabled",
  "plugin": [
    // always pin plugin versions
    "https://github.com/inkdust2021/opencode-vibeguard.git#f965b33468bafa27ac0654a04f5ed3c7c29c9b13",
    "@mohak34/opencode-notifier@0.2.4"
  ],
  "instructions": [
    "CONTRIBUTING.md",
    "docs/guidelines.md",
    ".cursor/rules/*.md",
    "CLAUDE.md",
    "AGENTS.md"
  ],
  "mcp": {
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer {file:./keys/github_pat}",
        "X-MCP-Toolsets": "context,repos,issues,pull_requests,actions,code_security,discussions,labels,projects,secret_protection,security_advisories,orgs,users,git"
      }
    },
    "code-docs-context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "grep-github": {
      "oauth": {},
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    "exa-web-search": {
      "oauth": {},
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?tools=web_search_exa,get_code_context_exa,crawling_exa,deep_researcher_start,deep_researcher_check"
    },
    "repo-info-deepwiki": {
      "type": "remote",
      "url": "https://mcp.deepwiki.com/mcp"
    }
  },
  "provider": {
    "openrouter": {
      "models": {},
      "options": {
        "data_collection": "deny"
      }
    },
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio",
      "options": {
        "baseURL": "http://localhost:1234/v1"
      },
      "models": {
        "gemma-4-12b-it-qat": {
          "name": "Gemma 4 12B Instruct QAT UD@gguf-Q4_K_XL",
          "limit": {
            "context": 262144,
            "output": 32768
          },
          "modalities": {
            "input": ["image", "text"],
            "output": ["text"]
          }
        },
        "johnnyasantoss/nex-n2-mini": {
          "name": "Nex N2 Mini 256x2.6B@gguf-Q4_K_M",
          "limit": {
            "context": 262144,
            "output": 32768
          },
          "modalities": {
            "input": ["image", "text"],
            "output": ["text"]
          }
        },
        "mellum2-12b-a2.5b-thinking_moe": {
          "name": "Mellum2 12B A2.5B Thinking MXFP4 MoE@gguf-uknw",
          "limit": {
            "context": 131072,
            "output": 32768
          }
        },
        "mlx-community/nex-n2-mini": {
          "name": "Nex N2 Mini@mlx-5bit",
          "limit": {
            "context": 262144,
            "output": 32768
          },
          "modalities": {
            "input": ["image", "text"],
            "output": ["text"]
          }
        },
        "qwen3.6-28b-reap20-a3b": {
          "name": "Qwen3.6 28B REAP20 A3B@gguf-Q4_K_M",
          "limit": {
            "context": 262144,
            "output": 32768
          }
        },
        "qwopus3.6-27b-v2-mtp": {
          "name": "Qwopus3.6 27B v2 MTP@gguf-Q4_K_M",
          "limit": {
            "context": 262144,
            "output": 32768
          },
          "modalities": {
            "input": ["image", "text"],
            "output": ["text"]
          }
        },
        "qwopus3.6-35b-a3b-v1-mtp": {
          "name": "Qwopus3.6 35B A3B v1 MTP@gguf-Q4_K_M",
          "limit": {
            "context": 262144,
            "output": 32768
          },
          "modalities": {
            "input": ["image", "text"],
            "output": ["text"]
          }
        }
      }
    }
  },
  "server": {
    "cors": [
      "http://localhost:4096",
      "http://opencode-macpro.local:4096",
      "https://macpro.sparrow-tet.ts.net"
    ],
    "mdns": true,
    "mdnsDomain": "opencode-macpro.local",
    "hostname": "127.0.0.1",
    "port": 4096,
    "password": "{file:./keys/oc_pass}"
  }
}
