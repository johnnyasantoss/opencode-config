            },
            "medium": {
              "reasoningEffort": "medium"
            },
            "high": {
              "reasoningEffort": "high"
            },
            "xhigh": {
              "reasoningEffort": "xhigh"
            }
          }
        },
        "qwen3.5-9b-claude-4.6-opus-reasoning-distilled-v2": {
          "name": "Qwen3.5 9B@gguf-Q5_K_M",
          "variants": {
            "none": {
              "reasoningEffort": "none"
            },
            "low": {
