{
  "$schema": "https://opencode.ai/config.json",
  "disabled_providers": [
    "zen"
  ],
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      ".git/**",
      "target/**"
    ]
  },
  "formatter": true,
  "lsp": true,
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000,
    "tail_turns": 1
  },
  "agent": {
    "general": {
      "model": "opencode-go/mimo-v2.5",
      "variant": "high"
    },
    "explore": {
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "medium"
    },
    "build": {
      "model": "opencode-go/mimo-v2.5",
      "variant": "high"
    },
    "title": {
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "low"
    },
    "summary": {
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "low"
    },
    "compaction": {
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "high"
    },
    "plan": {
      "model": "opencode-go/mimo-v2.5-pro",
      "variant": "max"
    },
    "git-master": {
      "model": "opencode-go/mimo-v2.5-pro"
    },
    "orchestrator": {
      "model": "opencode-go/mimo-v2.5-pro",
      "variant": "max"
    },
    "researcher": {
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "medium"
    },
    "review": {
      "model": "opencode-go/glm-5.2",
      "variant": "xhigh"
    }
  },
  "model": "opencode-go/glm-5.2",
  "small_model": "opencode-go/deepseek-v4-flash",
  "permission": {
    "edit": "allow",
    "bash": {
      "*": "ask",
      "cargo check*": "allow",
      "cargo clippy*": "allow",
      "cargo nextest*": "allow",
      "cargo test*": "allow",
      "cat*": "allow",
      "echo*": "allow",
      "fd *": "allow",
      "git branch*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git show*": "allow",
      "git status*": "allow",
      "grep*": "allow",
      "head*": "allow",
      "just*": "allow",
      "ls*": "allow",
      "rg*": "allow",
      "sleep ?": "allow",
      "sleep ??": "allow",
      "tail *": "allow",
      "wc*": "allow",
      "brew install *": "deny",
      "sudo *": "deny",
      "npm -g *": "deny",
      "npm install -g *": "deny",
      "bun install -g *": "deny",
      "cargo install *": "deny"
    }
  },
  "share": "disabled",
  "plugin": [
    // always pin plugin versions
    "https://github.com/inkdust2021/opencode-vibeguard.git#f965b33468bafa27ac0654a04f5ed3c7c29c9b13",
    "https://github.com/agustif/opencode-lmstudio.git#v0.3.1"
  ],
  "instructions": [
    "CONTRIBUTING.md",
    "docs/guidelines.md",
    ".cursor/rules/*.md",
    "CLAUDE.md",
    "AGENTS.md"
  ],
  "mcp": {
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer {file:./keys/github_pat}",
        "X-MCP-Toolsets": "context,repos,issues,pull_requests,actions,code_security,discussions,labels,projects,secret_protection,security_advisories,orgs,users,git"
      }
    },
    "code-docs-context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "grep-github": {
      "oauth": {},
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    "exa-web-search": {
      "oauth": {},
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?tools=web_search_exa,get_code_context_exa,crawling_exa,deep_researcher_start,deep_researcher_check"
    },
    "repo-info-deepwiki": {
      "type": "remote",
      "url": "https://mcp.deepwiki.com/mcp"
    }
  },
  "provider": {
    "openrouter": {
      "models": {},
      "options": {
        "data_collection": "deny"
      }
    },
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio",
      "options": {
        "timeout": 600000,
        "setCacheKey": true,
        "baseURL": "http://100.103.158.108:1234/v1"
      },
      "models": {
        // auto filled with opencode.override.json
      }
    }
  },
  "server": {
    "cors": [
      "http://localhost:4096",
      "http://opencode-macpro.local:4096",
      "https://macpro.sparrow-tet.ts.net"
    ],
    "mdns": true,
    "mdnsDomain": "opencode-macpro.local",
    "hostname": "127.0.0.1",
    "port": 4096,
    "password": "{file:./keys/oc_pass}"
  }
}
